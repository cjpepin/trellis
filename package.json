    "autoprefixer": "^10.4.20",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-electron": "^0.29.0"
  }
}
