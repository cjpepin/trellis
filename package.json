{
  "name": "trellis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "pnpm --filter @trellis/desktop run dev",
    "dev:web": "pnpm --filter @trellis/web run dev",
    "build:test-app": "pnpm --filter @trellis/desktop run build:test-app",
    "build:web": "pnpm --filter @trellis/web run build",
    "build:web:hosted": "pnpm --filter @trellis/web run build:hosted",
    "build:cap": "pnpm --filter @trellis/mobile run build:cap",
    "cap:open:ios": "pnpm --filter @trellis/mobile run cap:open:ios",
    "icons": "node scripts/process-app-icon.mjs",
    "icons:ios": "node scripts/iosAppIcon.mjs",
    "build": "pnpm --filter @trellis/desktop run build",
    "build:all": "pnpm --filter @trellis/desktop run build:all",
    "preview": "pnpm --filter @trellis/web run preview",
    "rebuild:native": "pnpm --filter @trellis/desktop run rebuild:native",
    "reset": "node scripts/reset.mjs",
    "preview:seed:generate": "node scripts/generate-preview-seed.mjs",
    "preview:seed:generate:heavy": "node scripts/generate-preview-seed.mjs heavy",
    "preview:seed:sync-web": "node scripts/sync-web-demo-seed.mjs",
    "test": "pnpm run check && pnpm run test:node",
    "test:all": "pnpm run verify",
    "test:node": "node scripts/run-node-tests-with-electron-restore.mjs",
    "test:supabase": "node scripts/run-supabase-tests.mjs",
    "test:config": "node scripts/run-node-tests.mjs tests/node/extraction/config.test.cjs",
    "test:contracts": "node scripts/run-node-tests.mjs tests/node/extraction/contract.test.cjs",
    "test:debug": "node scripts/run-node-tests.mjs tests/node/extraction/debug.test.cjs",
    "test:guardrails": "node scripts/run-node-tests.mjs tests/node/extraction/guardrails.test.cjs",
    "test:extraction-note-write": "node scripts/run-node-tests.mjs tests/node/extraction/note-write-regression.test.cjs",
    "test:jobs": "node scripts/run-node-tests.mjs tests/node/extraction/jobs.test.cjs",
    "test:preview-seed": "node scripts/run-node-tests.mjs tests/node/preview/seed.test.cjs",
    "test:providers": "node scripts/run-node-tests.mjs tests/node/extraction/provider.test.cjs",
    "test:retrieval": "node scripts/run-node-tests.mjs tests/node/retrieval/index.test.cjs",
    "test:e2e": "pnpm run build:test-app && playwright test --config config/playwright.config.ts",
    "test:e2e:headed": "pnpm run build:test-app && playwright test --config config/playwright.config.ts --headed",
    "verify": "pnpm run check && pnpm run test:node && pnpm run test:e2e",
    "eval:extraction:heuristic": "node scripts/extraction-eval.cjs heuristic",
    "eval:extraction:v2": "node scripts/extraction-eval.cjs v2",
    "eval:extraction:ollama": "node scripts/extraction-eval.cjs ollama",
    "supabase:doctor": "node scripts/supabase.mjs doctor",
    "supabase:login": "node scripts/supabase.mjs login",
    "supabase:link": "node scripts/supabase.mjs link",
    "supabase:start": "node scripts/supabase.mjs start",
    "supabase:stop": "node scripts/supabase.mjs stop",
    "supabase:status": "node scripts/supabase.mjs status",
    "supabase:db:push": "node scripts/supabase.mjs db:push",
    "supabase:db:reset": "node scripts/supabase.mjs db:reset",
    "supabase:db:diff": "node scripts/supabase.mjs db:diff",
    "supabase:migration:new": "node scripts/supabase.mjs migration:new",
    "supabase:types:gen": "node scripts/supabase.mjs types:gen",
    "supabase:functions:serve": "node scripts/supabase.mjs functions:serve",
    "supabase:functions:deploy": "node scripts/supabase.mjs functions:deploy",
    "supabase:backend:deploy": "node scripts/supabase.mjs backend:deploy",
    "security:check": "bash scripts/security-check.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tiptap/core": "3.23.4",
    "@tiptap/pm": "3.23.4",
    "@tiptap/react": "3.23.4",
    "@tiptap/starter-kit": "3.23.4",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "sucrase": "^3.35.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-electron": "^0.29.0"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "3.23.4",
      "@tiptap/pm": "3.23.4",
      "@tiptap/react": "3.23.4",
      "@tiptap/starter-kit": "3.23.4",
      "@tiptap/extension-color": "3.23.4",
      "@tiptap/extension-image": "3.23.4",
      "@tiptap/extension-link": "3.23.4",
      "@tiptap/extension-table": "3.23.4",
      "@tiptap/extension-table-cell": "3.23.4",
      "@tiptap/extension-table-header": "3.23.4",
      "@tiptap/extension-table-row": "3.23.4",
      "@tiptap/extension-text-style": "3.23.4",
      "tar": ">=7.5.11",
      "tmp": ">=0.2.6"
    }
  }
}
