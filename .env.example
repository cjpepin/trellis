# Set to 0 to disable on-device extraction (defaults to enabled).
TRELLIS_FEATURE_LOCAL_EXTRACTION=1

# Set to 0 to disable cloud extraction (on-device only). Default on when unset; requires API keys in Settings for OpenAI/Anthropic chat sessions.
TRELLIS_FEATURE_CLOUD_EXTRACTION=1

# Electron main: one-line latency breakdown when a job completes (prep vs primary LLM vs retry).
TRELLIS_LOG_EXTRACTION_TIMING=1

# Electron main: log extraction scheduling and job outcomes (counts and ids only; no message bodies).
TRELLIS_LOG_EXTRACTION=1

# Optional (Electron main). Override the default HTTPS URL for the on-device extraction GGUF download.
# TRELLIS_EMBEDDED_EXTRACTION_MODEL_URL=

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_STRIPE_CHECKOUT_URL=https://checkout.stripe.com/pay/example
VITE_SITE_URL=https://yourdomain.com
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_DOWNLOAD_MAC_URL=https://downloads.yourdomain.com/trellis-mac.zip
VITE_DOWNLOAD_MAC_VERSION=0.1.0

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Optional. Supabase Edge: secret sent as x-cron-secret or Authorization Bearer to account-expire-deletions (finalize profiles past deletion window). Falls back to CRON_SECRET if unset.
ACCOUNT_EXPIRE_CRON_SECRET=
# Electron main (cloud extraction, BYOK chat/media fallback): also read from the environment when not overridden by a BYOK key in Settings.
OPENAI_API_KEY=your-openai-key
OPENAI_CHAT_MODEL=gpt-4o
# Same pattern as OPENAI_API_KEY for Anthropic-backed paths in the Electron main process.
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
ANTHROPIC_EXTRACTION_MODEL=claude-3-5-haiku-latest
