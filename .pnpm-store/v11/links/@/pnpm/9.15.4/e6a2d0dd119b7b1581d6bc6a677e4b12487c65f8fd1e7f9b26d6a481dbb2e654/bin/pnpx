#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/connorpepin/Cursor/trellis/.pnpm-store/v11/links/@/pnpm/9.15.4/e6a2d0dd119b7b1581d6bc6a677e4b12487c65f8fd1e7f9b26d6a481dbb2e654/node_modules/pnpm/bin/pnpx.cjs
